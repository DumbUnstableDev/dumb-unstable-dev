# ======== Agent identity ========
TOKEN_MINT=                 # pump.fun token mint (set after launch)
TOKEN_TICKER=               # e.g. CEO
AGENT_PERSONA_NAME=         # e.g. $CEO
TWITTER_HANDLE=             # agent's X handle (no @)

# ======== Solana ========
RPC_URL=https://api.mainnet-beta.solana.com
TREASURY_SECRET_KEY=        # base58 secret key of the treasury hot wallet (MVP)
                            # v2: PDA signed via program — no hot key

# ======== Anthropic ========
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5
CLAUDE_MODEL_DEEP=claude-opus-4-7

# ======== Twitter (X) — Cookie auth (free, agent-twitter-client) ========
# Recommended for budget bots. Get cookies from x.com browser session:
# F12 → Application → Cookies → x.com → copy auth_token + ct0 values.
# Cookies expire ~30-90 days. If both set, this path is preferred over API keys.
# Risks: Twitter may detect automation and suspend the account. Use a burner.
TWITTER_AUTH_TOKEN=
TWITTER_CT0=
TWITTER_USERNAME=

# ======== Twitter (X) — Official API fallback (OAuth 1.0a) ========
# Used only when cookie creds (above) are not set.
TWITTER_APP_KEY=
TWITTER_APP_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=       # OAuth 2.0 app-only, for reads

# ======== Data sources ========
HELIUS_API_KEY=
PUMPPORTAL_WS=wss://pumpportal.fun/api/data
DEXSCREENER_BASE=https://api.dexscreener.com

# ======== Safety rails ========
MAX_SOL_PCT_PER_ACTION=0.20      # 20% of treasury per single action
MAX_ACTIONS_PER_DAY=12
COOLDOWN_MINUTES=20
MIN_CONFIDENCE=0.55
DRAWDOWN_HALT_PCT=0.30            # pause if treasury value down 30% in 24h

# ======== Operational ========
AGENT_PAUSED=0                    # 1 = kill switch, no txs will fire
DRY_RUN=1                         # 1 = no txs, no tweets, just logs (default safe)
MANUAL_APPROVAL=1                 # 1 = print decision + wait for y/n before executing
LOG_LEVEL=info

# Two-cadence schedule:
#   TICK_CRON  = main decision loop (action + tweet about it)
#   REPLY_CRON = reply-only loop (mentions → optional replies, no main action)
TICK_CRON=0 * * * *               # every hour at :00
REPLY_CRON=*/15 * * * *           # every 15 min

# Stealth-launch mode. When 1, validator blocks any tweet containing the
# mint / pump.fun coin URL; Claude gets cryptic-mode instructions.
# Flip to 0 via: node scripts/end-stealth.js
STEALTH_MODE=0

# Whale-event triggering — extra tick fires when a large buy/sell hits the token.
# Throttled so a burst of whales doesn't spam the timeline.
WHALE_THRESHOLD_SOL=5
WHALE_COOLDOWN_MIN=45

# ======== Optional ========
ARWEAVE_KEY_PATH=                 # for posting full reasoning; leave blank to skip

# ======== DexScreener Boost payments (for 'boost' action) ========
# On-chain DS recipient address (receives SOL per boost purchase).
# Leave blank to DISABLE the `boost` action entirely.
# Find the current address at https://dexscreener.com/boost (connect wallet → see payment address),
# or via their docs. Subject to change — check before each deploy cycle.
DS_BOOST_RECIPIENT=

# Tier prices in USD (override only if DS changes pricing; defaults shown below).
# DS_BOOST_10X_USD=99
# DS_BOOST_30X_USD=249
# DS_BOOST_50X_USD=399
# DS_BOOST_100X_USD=899
# DS_BOOST_500X_USD=3999

# ======== Optional HTTP status endpoint ========
STATUS_PORT=                      # e.g. 3030 to expose GET /status + /health (read-only)

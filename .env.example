# ======== Agent identity ========
TOKEN_MINT=                 # pump.fun token mint (set after launch)
TOKEN_TICKER=               # e.g. CEO
AGENT_PERSONA_NAME=         # e.g. $CEO
TWITTER_HANDLE=             # agent's X handle (no @)

# ======== Solana ========
RPC_URL=https://api.mainnet-beta.solana.com
TREASURY_SECRET_KEY=        # base58 secret key of the treasury hot wallet

# ======== Claude auth ========
# Pick ONE — priority order: ANTHROPIC_API_KEY → OPENROUTER_API_KEY → CLAUDE_CODE_OAUTH_TOKEN
# (the bot's claude.js falls through them in that order; first one set wins.)
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=    # optional: from `claude setup-token` if using Max plan

CLAUDE_MODEL=claude-sonnet-4-5
CLAUDE_MODEL_DEEP=claude-opus-4-7

# ======== Twitter (X) — OAuth 1.0a user context ========
TWITTER_APP_KEY=
TWITTER_APP_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=       # OAuth 2.0 app-only, for reads

# ======== Data sources ========
HELIUS_API_KEY=
PUMPPORTAL_WS=wss://pumpportal.fun/api/data
DEXSCREENER_BASE=https://api.dexscreener.com

# ======== Trading provider ========
# 'jupiter' (default, plain on-chain) or 'gmgn' (anti-MEV, faster routes).
TRADING_PROVIDER=jupiter
GMGN_API_KEY=               # required only when TRADING_PROVIDER=gmgn

# ======== Safety rails ========
MAX_SOL_PCT_PER_ACTION=0.20
MAX_ACTIONS_PER_DAY=48
COOLDOWN_MINUTES=20
MIN_CONFIDENCE=0.55
DRAWDOWN_HALT_PCT=0.30

# ======== Operational ========
AGENT_PAUSED=0
DRY_RUN=1
MANUAL_APPROVAL=1
LOG_LEVEL=info
TICK_CRON=*/30 * * * *

# ======== DexScreener Boost ========
# Wallet that receives the SOL-equivalent of a chosen tier when the agent
# decides to boost. Leave blank to disable the `boost` action entirely.
BOOST_PAYMENT_WALLET=

# ======== Optional HTTP /status endpoint ========
STATUS_PORT=                # e.g. 3030 → GET /status + /health (loopback by default)
# STATUS_HOST=127.0.0.1     # only set 0.0.0.0 if you also set STATUS_TOKEN
# STATUS_TOKEN=             # Bearer token if exposing publicly
